<%- include('partials/head', { title }) %>
<%- include('partials/header', { activePage }) %>

<style>
  .hero {
    padding: 5rem 0 3.5rem;
    text-align: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    background: var(--primary-pale);
    color: var(--primary-dark);
    font-size: .8rem;
    font-weight: 600;
    padding: .3rem .85rem;
    border-radius: 999px;
    margin-bottom: 1.4rem;
    border: 1px solid rgba(46,125,50,.2);
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }
  .hero h1 span {
    color: var(--primary);
  }
  .hero p {
    font-size: 1.08rem;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    gap: .75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Cards de navigation */
  .nav-cards {
    padding-bottom: 5rem;
  }
  .nav-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    text-decoration: none;
    color: var(--text-primary);
    display: block;
    transition: box-shadow .2s, transform .2s, border-color .2s;
    height: 100%;
  }
  .nav-card:hover {
    box-shadow: 0 6px 28px rgba(0,0,0,.1);
    transform: translateY(-3px);
    border-color: var(--primary);
    color: var(--text-primary);
  }
  .nav-card-icon {
    width: 48px;
    height: 48px;
    background: var(--primary-pale);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: var(--primary);
    margin-bottom: 1rem;
    transition: background-color var(--transition);
  }
  .nav-card:hover .nav-card-icon {
    background: var(--primary);
    color: #fff;
  }
  .nav-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: .4rem;
  }
  .nav-card p {
    font-size: .875rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.6;
  }
  .nav-card .card-arrow {
    margin-top: 1rem;
    font-size: .82rem;
    font-weight: 600;
    color: var(--primary);
    display: flex;
    align-items: center;
    gap: .3rem;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity .18s, transform .18s;
  }
  .nav-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>

<main>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">
        <i class="bi bi-mortarboard-fill"></i> Plateforme éducative
      </div>
      <h1>Bienvenue dans<br><span>l'espace de cours</span></h1>
      <p>Accédez aux cours, aux exercices interactifs et aux espaces dédiés aux élèves et aux professeurs.</p>
      <div class="hero-actions">
        <a href="/cours" class="btn btn-primary-app btn-lg px-4">
          <i class="bi bi-book-half me-2"></i>Voir les cours
        </a>
        <a href="/eleve" class="btn btn-outline-app btn-lg px-4">
          Espace Élève
        </a>
      </div>
    </div>
  </section>

  <!-- Cards -->
  <section class="nav-cards">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-4">
          <a href="/cours" class="nav-card">
            <div class="nav-card-icon"><i class="bi bi-journals"></i></div>
            <h3>Cours en ligne</h3>
            <p>Accédez à toutes les unités, leçons et contenus pédagogiques organisés par thème.</p>
            <div class="card-arrow">Accéder <i class="bi bi-arrow-right"></i></div>
          </a>
        </div>
        <div class="col-md-4">
          <a href="/eleve" class="nav-card">
            <div class="nav-card-icon"><i class="bi bi-person-check"></i></div>
            <h3>Espace Élève</h3>
            <p>Entrez votre code d'accès pour accéder aux exercices et formulaires de votre professeur.</p>
            <div class="card-arrow">Accéder <i class="bi bi-arrow-right"></i></div>
          </a>
        </div>
        <div class="col-md-4">
          <a href="/prof" class="nav-card">
            <div class="nav-card-icon"><i class="bi bi-shield-lock"></i></div>
            <h3>Espace Prof</h3>
            <p>Gérez l'accès à l'espace élève, configurez les exercices et activez ou désactivez l'espace.</p>
            <div class="card-arrow">Accéder <i class="bi bi-arrow-right"></i></div>
          </a>
        </div>
      </div>
    </div>
  </section>
</main>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- Fonctions communes -->
<script src="/assets/js/functions.js"></script>
</body>
</html>
