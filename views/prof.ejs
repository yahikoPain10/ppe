<%- include('partials/head', { title }) %>
<%- include('partials/header', { activePage }) %>

<style>
  .prof-bg {
    background-image: url('/static/prof-cover.jpg');
    background-color: #1a2a3a; /* fallback */
  }

  /* Dashboard (affiché après connexion, hors fond image) */
  #dashboardSection {
    display: none;
    background: var(--body-bg);
    padding: 2.5rem 1.5rem;
    min-height: calc(100vh - 60px);
  }

  .dashboard-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .dashboard-header h2 {
    font-size: 1.4rem;
    font-weight: 800;
    margin: 0;
    color: var(--text-primary);
  }

  .config-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: 0 2px 12px rgba(0,0,0,.05);
    transition: background-color var(--transition), border-color var(--transition);
  }

  .config-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: .5rem;
  }

  /* Toggle activer/désactiver */
  .status-toggle {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md);
    border: 1.5px solid var(--border-color);
    margin-bottom: 1.5rem;
    transition: border-color var(--transition), background-color var(--transition);
    cursor: pointer;
    user-select: none;
  }
  .status-toggle.enabled  { border-color: var(--primary); background: var(--primary-pale); }
  .status-toggle.disabled { border-color: var(--border-color); }

  .status-toggle-text strong {
    display: block;
    font-size: .95rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .status-toggle-text span {
    font-size: .82rem;
    color: var(--text-muted);
  }

  .big-toggle {
    position: relative;
    width: 52px;
    height: 28px;
    background: var(--border-color);
    border-radius: 999px;
    flex-shrink: 0;
    transition: background .2s;
  }
  .big-toggle::after {
    content: '';
    position: absolute;
    top: 3px; left: 3px;
    width: 22px; height: 22px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 1px 4px rgba(0,0,0,.25);
    transition: transform .2s;
  }
  .enabled .big-toggle { background: var(--primary); }
  .enabled .big-toggle::after { transform: translateX(24px); }

  .form-hint {
    font-size: .78rem;
    color: var(--text-muted);
    margin-top: .3rem;
  }
</style>

<main>
  <!-- ── Zone connexion (fond image) ──────────────────────────────────────── -->
  <div id="loginSection" class="page-bg-full prof-bg">

    <div class="form-card">
      <img src="/static/logo.svg" class="card-logo" alt="Logo"
           onerror="this.style.display='none'">
      <h2>Espace Prof</h2>
      <p class="card-subtitle">Connectez-vous pour gérer l'espace élève.</p>

      <div id="loginError" class="alert-app alert-danger mb-3 d-none">
        <i class="bi bi-exclamation-circle-fill"></i>
        <span id="loginErrorMsg"></span>
      </div>

      <form id="loginForm" autocomplete="off" novalidate>
        <div class="mb-3">
          <label class="form-label" for="usernameInput">Nom d'utilisateur</label>
          <input type="text" class="form-control" id="usernameInput"
                  required autocomplete="username">
        </div>
        <div class="mb-3">
          <label class="form-label" for="passwordInput">Mot de passe</label>
          <div class="input-group">
            <input type="password" class="form-control" id="passwordInput"
                    required autocomplete="current-password" id="passwordInput">
            <button class="btn btn-outline-secondary" type="button" id="togglePassword"
                    tabindex="-1" style="border-color:var(--border-color)">
              <i class="bi bi-eye" id="togglePasswordIcon"></i>
            </button>
          </div>
        </div>
        <button type="submit" class="btn btn-primary-app w-100 mt-1" id="loginBtn">
          <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
        </button>
      </form>
    </div>

  </div>

  <!-- ── Dashboard (affiché après connexion) ──────────────────────────────── -->
  <div id="dashboardSection">
    <div class="container" style="max-width:720px">

      <div class="dashboard-header">
        <h2><i class="bi bi-shield-check me-2 text-success"></i>Tableau de bord</h2>
        <button class="btn btn-outline-app btn-sm" id="logoutBtn">
          <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
        </button>
      </div>

      <!-- Card 1 : Activer / Désactiver -->
      <div class="config-card mb-3">
        <h3><i class="bi bi-toggle-on text-success"></i> Accès élève</h3>

        <div class="status-toggle disabled" id="statusToggle">
          <div class="big-toggle" id="bigToggle"></div>
          <div class="status-toggle-text">
            <strong id="statusLabel">Désactivé</strong>
            <span id="statusDesc">Les élèves ne peuvent pas accéder à l'espace.</span>
          </div>
        </div>
      </div>

      <!-- Card 2 : Configuration (visible seulement si activé) -->
      <div class="config-card" id="configForm" style="display:none">
        <h3><i class="bi bi-gear text-secondary"></i> Configuration</h3>

        <form id="saveConfigForm" novalidate>
          <div class="mb-3">
            <label class="form-label" for="googleFormLinkInput">Lien Google Form</label>
            <input type="url" class="form-control" id="googleFormLinkInput"
                   placeholder="https://docs.google.com/forms/d/…">
            <p class="form-hint">Le formulaire que les élèves verront après avoir saisi leur code.</p>
          </div>

          <div class="mb-3">
            <label class="form-label" for="secretInput">
              Nouveau code d'accès
              <span id="hasSecretBadge" class="badge bg-success ms-1" style="display:none;font-size:.7rem">
                <i class="bi bi-check-circle me-1"></i>Défini
              </span>
            </label>
            <input type="password" class="form-control" id="secretInput"
                   placeholder="Laisser vide pour conserver l'actuel"
                   autocomplete="new-password">
            <p class="form-hint">Le code que les élèves saisissent pour accéder au formulaire. Laissez vide pour ne pas le modifier.</p>
          </div>

          <button type="submit" class="btn btn-primary-app" id="saveBtn">
            <i class="bi bi-floppy me-2"></i>Enregistrer
          </button>
        </form>
      </div>

    </div>
  </div>
</main>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/assets/js/functions.js"></script>
<script>
  // Token JWT en mémoire uniquement (perdu au reload → retour login)
  let authToken = null;

  // ── Toggle affichage mot de passe ─────────────────────────────────────────
  $('#togglePassword').on('click', function () {
    const inp = document.getElementById('passwordInput');
    const icon = document.getElementById('togglePasswordIcon');
    if (inp.type === 'password') {
      inp.type = 'text';
      icon.className = 'bi bi-eye-slash';
    } else {
      inp.type = 'password';
      icon.className = 'bi bi-eye';
    }
  });

  // ── Connexion ─────────────────────────────────────────────────────────────
  $('#loginForm').on('submit', function (e) {
    e.preventDefault();
    $('#loginError').addClass('d-none');

    const username = $('#usernameInput').val().trim();
    const password = $('#passwordInput').val();

    if (!username || !password) {
      showLoginError('Veuillez remplir tous les champs.');
      return;
    }

    setBtnLoading('#loginBtn', true);

    apiCall('/api/auth/login', {
      method: 'POST',
      data: { username, password },
    })
      .then(function (res) {
        authToken = res.token;
        loadDashboard();
      })
      .catch(function (err) {
        setBtnLoading('#loginBtn', false);
        showLoginError(err.data?.message || 'Identifiants incorrects.');
      });
  });

  function showLoginError(msg) {
    $('#loginErrorMsg').text(msg);
    $('#loginError').removeClass('d-none');
  }

  // ── Chargement du dashboard ───────────────────────────────────────────────
  function loadDashboard() {
    apiCallAuth('/api/espace-eleve/config', authToken, { method: 'GET' })
      .then(function (res) {
        renderDashboard(res.data);
        $('#loginSection').hide();
        $('#dashboardSection').show();
      })
      .catch(function (err) {
        if (err.status === 401) { authToken = null; location.reload(); }
        else showToast('Erreur lors du chargement.', 'error');
      });
  }

  // ── Rendu du dashboard ────────────────────────────────────────────────────
  function renderDashboard(data) {
    updateToggleUI(data.isEnabled);
    $('#googleFormLinkInput').val(data.googleFormLink || '');

    if (data.hasSecret) {
      $('#hasSecretBadge').show();
    } else {
      $('#hasSecretBadge').hide();
    }

    if (data.isEnabled) {
      $('#configForm').show();
    } else {
      $('#configForm').hide();
    }
  }

  // ── Toggle activer / désactiver ───────────────────────────────────────────
  $('#statusToggle').on('click', function () {
    const isCurrentlyEnabled = $(this).hasClass('enabled');
    const newState = !isCurrentlyEnabled;

    apiCallAuth('/api/espace-eleve/config', authToken, {
      method: 'PUT',
      data: { isEnabled: newState },
    })
      .then(function (res) {
        renderDashboard(res.data);
        showToast(
          newState ? 'Espace élève activé.' : 'Espace élève désactivé.',
          newState ? 'success' : 'info'
        );
      })
      .catch(function (err) {
        if (err.status === 401) { authToken = null; location.reload(); }
        else showToast('Erreur lors de la mise à jour.', 'error');
      });
  });

  function updateToggleUI(isEnabled) {
    const $toggle = $('#statusToggle');
    if (isEnabled) {
      $toggle.addClass('enabled').removeClass('disabled');
      $('#statusLabel').text('Activé');
      $('#statusDesc').text('Les élèves peuvent accéder à l\'espace avec leur code.');
    } else {
      $toggle.addClass('disabled').removeClass('enabled');
      $('#statusLabel').text('Désactivé');
      $('#statusDesc').text('Les élèves ne peuvent pas accéder à l\'espace.');
    }
  }

  // ── Enregistrement de la configuration ───────────────────────────────────
  $('#saveConfigForm').on('submit', function (e) {
    e.preventDefault();

    const googleFormLink = $('#googleFormLinkInput').val().trim();
    const secret         = $('#secretInput').val().trim();

    const payload = { googleFormLink };
    if (secret) payload.secret = secret;

    setBtnLoading('#saveBtn', true);

    apiCallAuth('/api/espace-eleve/config', authToken, {
      method: 'PUT',
      data: payload,
    })
      .then(function (res) {
        setBtnLoading('#saveBtn', false);
        renderDashboard(res.data);
        $('#secretInput').val('');
        showToast('Configuration enregistrée.', 'success');
      })
      .catch(function (err) {
        setBtnLoading('#saveBtn', false);
        if (err.status === 401) { authToken = null; location.reload(); }
        else showToast(err.data?.message || 'Erreur lors de l\'enregistrement.', 'error');
      });
  });

  // ── Déconnexion ───────────────────────────────────────────────────────────
  $('#logoutBtn').on('click', function () {
    authToken = null;
    location.reload();
  });
</script>
</body>
</html>
