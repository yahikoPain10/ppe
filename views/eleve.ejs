<%- include('partials/head', { title }) %>
<%- include('partials/header', { activePage }) %>

<style>
  .eleve-bg {
    background-image: url('/static/prof-cover.jpg');
    background-color: #1a3c34; /* fallback si image absente */
  }

  #formContent { display: none; }
  #formEmbedSection { display: none; }

  .google-form-frame {
    width: 100%;
    height: 75vh;
    min-height: 520px;
    border: none;
    border-radius: var(--radius-md);
    display: block;
  }

  .embed-wrapper {
    background: var(--card-bg);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: 0 8px 40px rgba(0,0,0,.28);
    width: 100%;
    max-width: 820px;
  }

  .embed-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .embed-header h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-primary);
  }
</style>

<main>
  <!-- Zone avec fond image -->
  <div class="page-bg-full eleve-bg">

    <!-- ① Spinner de chargement initial -->
    <div id="loadingState" class="form-card text-center">
      <span class="spinner-app me-2" style="border-color:var(--primary);border-right-color:transparent"></span>
      <span style="color:var(--text-muted); font-size:.9rem;">Vérification…</span>
    </div>

    <!-- ② Espace désactivé -->
    <div id="disabledState" class="form-card" style="display:none">
      <div class="text-center mb-3">
        <i class="bi bi-lock-fill" style="font-size:2.2rem; color:var(--text-muted)"></i>
      </div>
      <h2 class="text-center">Espace Élève</h2>
      <p class="card-subtitle text-center">
        L'espace élève est actuellement <strong>fermé</strong>.<br>
        Revenez plus tard ou contactez votre professeur.
      </p>
    </div>

    <!-- ③ Formulaire d'accès (code secret) -->
    <div id="formContent" class="form-card">
      <img src="/static/logo.svg" class="card-logo" alt="Logo"
           onerror="this.style.display='none'">
      <h2>Espace Élève</h2>
      <p class="card-subtitle">Entrez le code d'accès fourni par votre professeur.</p>

      <form id="accessForm" autocomplete="off" novalidate>
        <div class="mb-3">
          <label class="form-label" for="secretInput">Code d'accès</label>
          <input type="password" class="form-control" id="secretInput" autocomplete="off" required>
          <div id="secretError" class="text-danger mt-1 d-none" style="font-size:.82rem;"></div>
        </div>
        <button type="submit" class="btn btn-primary-app w-100" id="accessBtn">
          <i class="bi bi-unlock-fill me-2"></i>Accéder
        </button>
      </form>
    </div>

  </div>

  <!-- ④ Formulaire Google intégré (pleine largeur, hors section fond) -->
  <div id="formEmbedSection"
       style="background:var(--body-bg); padding:2rem; display:flex; justify-content:flex-start;">
    <div class="embed-wrapper">
      <div class="embed-header">
        <h3><i class="bi bi-ui-checks me-2 text-success"></i>Exercice en ligne</h3>
        <button class="btn btn-outline-app btn-sm" id="logoutEleveBtn">
          <i class="bi bi-box-arrow-left me-1"></i>Quitter
        </button>
      </div>
      <iframe id="googleFormFrame" class="google-form-frame"
              src="" title="Exercice Google Forms"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope">
      </iframe>
    </div>
  </div>
</main>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/assets/js/functions.js"></script>
<script>
  // ── Vérification du statut de l'espace élève au chargement ────────────────
  $(document).ready(function () {
    checkEleveStatus();
  });

  function checkEleveStatus() {
    apiCall('/api/espace-eleve/status', { method: 'GET' })
      .then(function (res) {
        $('#loadingState').hide();
        if (res.data.isEnabled) {
          $('#formContent').show();
        } else {
          $('#disabledState').show();
        }
      })
      .catch(function () {
        $('#loadingState').hide();
        $('#disabledState').show();
      });
  }

  // ── Soumission du formulaire d'accès ──────────────────────────────────────
  $('#accessForm').on('submit', function (e) {
    e.preventDefault();
    setFieldError('#secretError', null);

    const secret = $('#secretInput').val().trim();
    if (!secret) {
      setFieldError('#secretError', 'Veuillez entrer un code d\'accès.');
      return;
    }

    setBtnLoading('#accessBtn', true);

    apiCall('/api/eleve/verify', {
      method: 'POST',
      data: { secret },
    })
      .then(function (res) {
        // Succès → intégrer le formulaire Google
        embedGoogleForm(res.data.googleFormLink);
      })
      .catch(function (err) {
        setBtnLoading('#accessBtn', false);
        const msg = err.data?.message || 'Code incorrect. Réessayez.';
        setFieldError('#secretError', msg);
        showToast(msg, 'error');
      });
  });

  // ── Intégration du formulaire Google ─────────────────────────────────────
  function embedGoogleForm(link) {
    if (!link) {
      showToast('Aucun formulaire configuré pour le moment.', 'warning');
      setBtnLoading('#accessBtn', false);
      return;
    }

    // Convertir le lien Google Form en URL intégrable
    const embedUrl = link.replace('/viewform', '/viewform?embedded=true')
                         .replace('/edit', '/viewform?embedded=true');

    $('#googleFormFrame').attr('src', embedUrl);

    // Masquer la section fond image, afficher la zone d'intégration
    $('.page-bg-full').hide();
    $('#formEmbedSection').show();
  }

  // ── Bouton quitter l'espace élève ─────────────────────────────────────────
  $('#logoutEleveBtn').on('click', function () {
    $('#googleFormFrame').attr('src', '');
    $('#formEmbedSection').hide();
    $('#secretInput').val('');
    setBtnLoading('#accessBtn', false);
    $('.page-bg-full').show();
  });
</script>
</body>
</html>
