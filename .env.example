# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/cours-app

# ── Authentification Prof ─────────────────────────────────────────────────────
# Le nom d'utilisateur du professeur (en clair)
PROF_USERNAME=professeur

# Le mot de passe du professeur hashé en SHA-256 (en minuscules)
# Exemple pour générer : echo -n "monMotDePasse" | sha256sum
# Valeur exemple pour le mot de passe "admin1234" :
PROF_PASSWORD_SHA256=ac9689e2272427085e35b9d3e3e8bed88cb3434828b43b86fc0596cad4c6e270

# ── JWT ───────────────────────────────────────────────────────────────────────
# Une chaîne longue et aléatoire, ex: openssl rand -hex 64
JWT_SECRET=changez_moi_avec_une_cle_secrete_tres_longue_et_aleatoire
